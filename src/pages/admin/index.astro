---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Admin - Tante Edith">
  <main class="admin-shell hidden" id="admin-shell">
    <section class="admin-card">
      <div class="admin-header">
        <h2>Admin Settings</h2>
        <div class="admin-header-actions">
          <a href="/">Zur Webseite</a>
          <button type="button" id="logout-btn">Logout</button>
        </div>
      </div>

      <form id="settings-form" class="admin-form">
        <label>
          Öffnungszeiten
          <textarea name="opening_times" rows="4"></textarea>
        </label>

        <label>
          Email
          <input type="text" name="email" />
        </label>

        <label>
          Telefonnummer
          <input type="text" name="phone_number" />
        </label>

        <label>
          Adresse
          <input type="text" name="address" />
        </label>


        <button type="submit">Speichern</button>
        <p class="status-line" id="save-status"></p>
      </form>
    </section>
  </main>

  <script>
    import { supabase } from "../../lib/supabase";
    import { fetchSettings, saveSettings } from "../../lib/settings";

    const adminShell = document.getElementById("admin-shell");
    const form = document.getElementById("settings-form") as HTMLFormElement | null;
    const statusEl = document.getElementById("save-status");
    const logoutBtn = document.getElementById("logout-btn");

    const { data } = await supabase.auth.getSession();
    if (!data.session) {
      window.location.href = "/admin/login";
    } else {
      adminShell?.classList.remove("hidden");
    }

    const settings = await fetchSettings();
    if (settings && form) {
      const openingTimesField = form.elements.namedItem("opening_times") as HTMLTextAreaElement | null;
      const specialNoticeField = form.elements.namedItem("special_notice") as HTMLTextAreaElement | null;
      const phoneField = form.elements.namedItem("phone_number") as HTMLInputElement | null;
      const emailField = form.elements.namedItem("email") as HTMLInputElement | null;
      const addressField = form.elements.namedItem("address") as HTMLInputElement | null;
      const reservationField = form.elements.namedItem("reservation_note") as HTMLTextAreaElement | null;

      if (openingTimesField) openingTimesField.value = settings.opening_times ?? "";
      if (specialNoticeField) specialNoticeField.value = settings.special_notice ?? "";
      if (phoneField) phoneField.value = settings.phone_number ?? "";
      if (emailField) emailField.value = settings.email ?? "";
      if (addressField) addressField.value = settings.address ?? "";
      if (reservationField) reservationField.value = settings.reservation_note ?? "";
    }

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form) return;

      const formData = new FormData(form);

      try {
        await saveSettings({
          opening_times: String(formData.get("opening_times") || ""),
          address: String(formData.get("address") || ""),
          email: String(formData.get("email") || ""),
          phone_number: String(formData.get("phone_number") || ""),
        });

        if (statusEl) statusEl.textContent = "Gespeichert.";
      } catch (error) {
        if (statusEl) statusEl.textContent = "Fehler beim Speichern.";
      }
    });

    logoutBtn?.addEventListener("click", async () => {
      await supabase.auth.signOut();
      window.location.href = "/admin/login";
    });
  </script>
</BaseLayout>
